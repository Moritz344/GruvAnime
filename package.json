{
  "name": "gruvanime",
  "version": "0.0.0",
  "main": "main.js",
  "scripts": {
    "ng": "ng",
    "start": "concurrently \"ng serve\" \"wait-on http://localhost:4200 && npm run electron-dev\"",
    "electron-dev": "cross-env ELECTRON_DEV=true electron .",
    "build": "ng build",
    "build:electron": "ng build && electron-builder --linux AppImage",
    "electron-prod": "ng build && electron ."
  },
  "build": {
    "files": [
      "dist/**",
      "main.js",
      "preload.js",
      "package.json"
    ]
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.7.0",
  "dependencies": {
    "@angular/animations": "^21.0.6",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@supabase/supabase-js": "^2.95.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "is-electron": "^2.2.2",
    "ngx-device-detector": "^11.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "wait-on": "^9.0.5"
  },
  "devDependencies": {
    "@angular/build": "^21.0.2",
    "@angular/cli": "^21.0.2",
    "@angular/compiler-cli": "^21.0.0",
    "electron-builder": "^26.8.1",
    "@types/node": "^25.2.2",
    "jsdom": "^27.1.0",
    "electron": "^41.2.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
